          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"accessToken not null\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.accessToken).to.not.be.null;",
              "});",
              "",
              "",
              "const responseJson = pm.response.text();",
              "pm.collectionVariables.set(\"accessToken\", responseJson.accessToken)",
              "pm.collectionVariables.set(\"user_id\", responseJson.id)"
            ],
