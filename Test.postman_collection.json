    {
      "name": "carts_add_201",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"ID is not null\", function () {",
              "    pm.response.to.have.jsonBody('id');",
              "    });",
              "",
              "pm.test(\"User ID is not null\", function () {",
              "    pm.expect(pm.response.json().userId).to.not.be.null;",
              "    });",
              "",
              "pm.test(\"User ID matches the environment variable\", function () {",
              "    pm.expect(pm.response.json().userId).to.eql(pm.environment.get(\"user_id\"));",
              "});",
              "",
              "",
              "const responseJson = pm.response.text();",
              "pm.collectionVariables.set(\"cart_ID\", responseJson.id)",
              "pm.collectionVariables.set(\"totalProducts\", responseJson.totalProducts)",
              "pm.collectionVariables.set(\"totalQuantity\", responseJson.totalQuantity)",
              "pm.collectionVariables.set(\"total\", responseJson.total)"
            ],
